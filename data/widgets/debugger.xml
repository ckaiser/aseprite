<gui>
<window id="debugger" text="@.title">
  <vbox>
    <label id="connect_hint" text="Connect using any DAP-compatible debuggers via localhost" />
    <hbox>
      <label text="Port:" for="port_entry" />
      <entry id="port_entry" maxsize="5" placeholder="58000" />
    </hbox>
    <separator horizontal="true" />
    <hbox>
      <link text="[Learn More]" url="https://www.aseprite.org/docs/scripting/#TODO-FILL-ME-OUT" />
      <boxfiller />
      <button id="enable_debugger" magnet="true" text="Enable Debugger" />
      <button id="disable_debugger" text="Disable Debugger" disabled="true" />
    </hbox>
  </vbox>
</window>
</gui>
