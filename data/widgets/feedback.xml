<gui>
<window id="feedback" text="Feedback">
  <vbox>
    <buttonset columns="3" minheight="64" id="dir">
      <item icon="aseprite_face_mouse" />
      <item icon="aseprite_face" />
      <item icon="aseprite_face_pushed" />
    </buttonset>
   
    <entry_multiline width="210" height="44" text="@test.multiline_entry" expansive="true" />
    
    <hbox>
      <link text="More information..." url="https://www.aseprite.org/" />
      <boxfiller />
      <button text="Submit" id="submit" minwidth="60" />
      <button text="@general.close" closewindow="true" id="ok" magnet="true" minwidth="60" />
    </hbox>
  </vbox>
</window>
</gui>
