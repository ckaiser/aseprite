<gui>
<window id="script_access" text="@.title" minwidth="256">
  <vbox expansive="true">
    <hbox expansive="true" childspacing="0">
      <label id="requires_preamble" />
      <link id="origin_link" tooltip="@.click_for_more" tooltip_dir="bottom" />
      <label text="@.requires_permission" />
    </hbox>

    <hbox expansive="true">
      <image id="permission_icon" icon="combobox_arrow_right" />

      <vbox expansive="true">
        <label id="permission_label" />
        <textbox id="permission_warning" wordwrap="true" maxwidth="256" style="textbox_label" />
      </vbox>
    </hbox>

    <label id="wants" />

    <view id="url_view" height="18" expansive="true">
      <textedit id="url_text" readonly="true" style="textedit_static" />
    </view>

    <check id="remember" text="@.remember" />
    <check id="remember_file" text="@.remember_file" visible="false" />
    <check id="remember_directory" text="@.remember_directory" visible="false" />

    <separator horizontal="true" />
    <hbox>
      <button id="dotdotdot" text="..." />
      <boxfiller />
      <button id="allow" closewindow="true" text="@.allow" disabled="true" magnet="true" minwidth="45" />
      <button id="deny" text="@.deny" closewindow="true" minwidth="45" />
    </hbox>
  </vbox>
</window>
</gui>
